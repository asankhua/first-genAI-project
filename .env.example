# Zomato AI Recommender - Environment variables
# Copy to .env and fill in your values. Do not commit .env (it contains secrets).

# Groq API key (required for AI-powered recommendations)
# Create at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Hugging Face token (optional; for gated/private datasets)
# Create at: https://huggingface.co/settings/tokens
# HF_TOKEN=your_hf_token_here

# API base URL (for Streamlit when backend runs elsewhere)
# API_BASE_URL=http://localhost:8000

# Optional: path to cleaned data CSV (default: phase4/data/cleaned.csv)
# CLEANED_DATA_PATH=phase4/data/cleaned.csv
